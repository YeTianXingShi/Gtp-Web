{
  // 统一维护所有可用模型；标准 JSON 也可以，另外支持 // 与 /* */ 注释。
  "openai": {
    "image_model": "",
    "defaults": {
      "reasoning": {
        "effort": "high",
        "summary": "auto"
      }
    },
    "models": [
      {
        "name": "gpt-5.2"
      },
      {
        "name": "gpt-5.4"
