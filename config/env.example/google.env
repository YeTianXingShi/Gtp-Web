# 留空表示使用 Gemini 官方默认地址；需要代理或网关时再填写。
GOOGLE_BASE_URL=
GOOGLE_API_KEY=AIza-your-key
GOOGLE_MODELS=gemini-2.0-flash,gemini-2.5-pro
GOOGLE_INCLUDE_THOUGHTS=1
GOOGLE_THINKING_LEVEL=medium
# Gemini 2.5 可按需配置 thinking budget；留空表示不显式传递。
GOOGLE_THINKING_BUDGET=
# 留空表示禁用基于 Google 的 dalle.text2im 图片生成；例如 imagen-3.0-generate-002
GOOGLE_IMAGE_MODEL=
