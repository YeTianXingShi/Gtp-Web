{
  // 统一维护所有可用模型；标准 JSON 也可以，另外支持 // 与 /* */ 注释。
  //
  // 说明：
  // 1. 每个模型都可以独立配置自己的 reasoning / thinking。
  // 2. `enabled` 用来控制该模型是否启用思考能力。
  // 3. OpenAI 支持：`enabled`、`effort`、`summary`
  // 4. Google 支持：`enabled`、`include_thoughts`、`level`、`budget`
  // 5. 兼容旧写法：把 `reasoning` / `thinking` 直接写成 false 或 null，依然表示关闭。
  "openai": {
    "image_model": "",
    "models": [
      {
        "name": "gpt-5.2",
        "label": "GPT-5.2（高强度推理）",
        "reasoning": {
          "enabled": true,
          "effort": "high",
          "summary": "auto"
        }
      },
      {
        "name": "gpt-5.4",
        "label": "GPT-5.4（轻量推理）",
        "reasoning": {
          "enabled": true,
          "effort": "medium",
          "summary": "concise"
        }
      }
    ]
  },
  "google": {
    "image_model": "gemini-3.1-flash-image-preview",
    "models": [
      {
        "name": "gemini-3-flash-preview",
        "label": "Gemini 3 Flash（中等思考）",
        "thinking": {
          "enabled": true,
          "include_thoughts": true,
          "level": "medium"
        }
      },
      {
        "name": "gemini-3-pro-preview",
        "label": "Gemini 3 Pro（开启思考但不回传 thoughts）",
        "thinking": {
          "enabled": true,
          "include_thoughts": false,
          "level": "high"
        }
      },
      {
        "name": "gemini-3.1-pro-preview",
        "label": "Gemini 3.1 Pro（按预算思考）",
        "thinking": {
          "enabled": true,
          "include_thoughts": true,
          "budget": 8192,
          "level": "high"
        }
      }
    ]
  }
}
